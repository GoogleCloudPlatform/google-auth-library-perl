FROM docker.io/library/ubuntu:latest

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y \
    perl perl-modules cpanminus liblocal-lib-perl libtemplate-perl \
    gcc g++ make libssl-dev libcrypt-dev libnghttp2-dev libpcre2-dev libabsl-dev pkg-config protobuf-compiler \
    libwww-perl libjson-xs-perl libjson-maybexs-perl libmoo-perl libtype-tiny-perl \
    libpath-tiny-perl liblog-any-perl libcapture-tiny-perl liburi-perl libfile-which-perl libmodule-starter-perl \
    libtest-exception-perl libtest-deep-perl libtest-mockmodule-perl && \
    cpanm --notest Protocol::HTTP2 Test::LWP::UserAgent Perl::Tidy Perl::Critic Test::Perl::Critic && \
    rm -rf ~/.cpanm /var/lib/apt/lists/*

